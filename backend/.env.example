# Server Configuration
PORT=8000
ENVIRONMENT=production
DEBUG=False

# Database Configuration
# Replace with your actual MongoDB Atlas or local MongoDB URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/agrisathi?retryWrites=true&w=majority
DB_NAME=agrisathi_prod

# Authentication & Security
# Generate a strong secret key: `openssl rand -hex 32`
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200 # 30 days

# External APIs
# Get your Gemini API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here
# Weather API (e.g. OpenWeatherMap)
WEATHER_API_KEY=your_weather_api_key_here

# Firebase Configuration
# Path to your Firebase service account JSON file for push notifications
FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase-adminsdk.json

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://agrisathi.com,https://admin.agrisathi.com
